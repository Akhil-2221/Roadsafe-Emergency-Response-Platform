# ═══════════════════════════════════════════════════════════════
# RoadSafe Emergency — Environment Variables
# Copy this to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ─── App ─────────────────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000
PORT=3001

# ─── Database (PostgreSQL) ────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:Akhil123@localhost:5432/roadsafe
DB_PASSWORD=your_password_here

# ─── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://:your_redis_password@localhost:6379
REDIS_PASSWORD=your_redis_password

# ─── JWT Auth ────────────────────────────────────────────────────
# IMPORTANT: Generate strong secrets. Use: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_openssl_rand_hex_32_output_here
JWT_REFRESH_SECRET=REPLACE_WITH_ANOTHER_openssl_rand_hex_32_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── QR Signing ──────────────────────────────────────────────────
# Used to sign QR tokens — NEVER change this in production (breaks all QRs)
QR_JWT_SECRET=REPLACE_WITH_openssl_rand_hex_32_for_qr

# ─── Security ────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
COOKIE_SECRET=REPLACE_WITH_openssl_rand_hex_32_for_cookies
ALLOWED_ORIGINS=http://localhost:3000

# ─── AI Service ──────────────────────────────────────────────────
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# Internal service authentication (optional but recommended)
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_KEY=REPLACE_WITH_openssl_rand_hex_16

# ─── Twilio (SMS + WhatsApp) ──────────────────────────────────────
# Get from: https://console.twilio.com/
# Required for SMS emergency notifications
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_FROM=
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886   # Twilio sandbox number

# ─── SendGrid (Email) ─────────────────────────────────────────────
# Get from: https://app.sendgrid.com/settings/api_keys
# Required for email notifications and verification
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@roadsafe.in
SENDGRID_FROM_NAME=RoadSafe Emergency

# ─── Firebase (Push Notifications) ───────────────────────────────
# Get from: Firebase Console > Project Settings > Cloud Messaging
FIREBASE_SERVER_KEY=AAAAxxxxxxx:APAxxx...

# ─── AWS (File Storage) ───────────────────────────────────────────
# Required for storing accident photos, QR images
# Create an S3 bucket in ap-south-1 (Mumbai)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
S3_BUCKET=roadsafe-media-prod

# ─── Google Maps ──────────────────────────────────────────────────
# Required for hospital directions, live nearby hospital/police search,
# and reverse geocoding of accident locations
# Get from: console.cloud.google.com (enable Places API + Geocoding API)
GOOGLE_MAPS_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Bystander Verification ─────────────────────────────────────────
# When true, bystanders must verify their phone via OTP before an
# emergency event can be created. Adds friction but reduces false/abusive
# reports. Default is false to keep the fastest path for real emergencies.
REQUIRE_BYSTANDER_OTP=true

# ─── Medical Data Encryption (optional, recommended for production) ─
# 32-byte hex key for AES-256 encryption of medical fields
# Generate: openssl rand -hex 32
MEDICAL_ENCRYPTION_KEY=

# ─── Frontend (.env.local in apps/web/) ───────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_GOOGLE_MAPS_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
